{
  "routes": [
    {
      "route": "/.auth/login/google/callback",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/.auth/login/github/callback",
      "allowedRoles": ["anonymous", "authenticated"]
    },
    {
      "route": "/ai-360/login.html",
      "serve": "/ai-360/login.html",
      "statusCode": 200
    },
    {
      "route": "/ai-360/register.html",
      "serve": "/ai-360/register.html",
      "statusCode": 200
    },
    {
      "route": "/ai-360/ai-tools.html",
      "serve": "/ai-360/ai-tools.html",
      "statusCode": 200
    },
    {
      "route": "/",
      "redirect": "/ai-360/login.html",
      "statusCode": 302
    },
    {
      "route": "/ai-360",
      "redirect": "/ai-360/login.html",
      "statusCode": 302
    },
    {
      "route": "/ai-360/index.html",
      "serve": "/ai-360/index.html",
      "allowedRoles": ["authenticated"],
      "statusCode": 200
    }
  ],
  "navigationFallback": {
    "rewrite": "/ai-360/index.html",
    "exclude": ["/ai-360/login.html", "/ai-360/register.html", "/ai-360/ai-tools.html", "/.auth/*", "*.{css,scss,js,png,gif,ico,jpg,svg}"]
  },
  "auth": {
    "identityProviders": {
      "google": {
        "registration": {
          "clientIdSettingName": "GOOGLE_CLIENT_ID",
          "clientSecretSettingName": "GOOGLE_CLIENT_SECRET"
        },
        "login": {
          "scopes": ["openid", "profile", "email"]
        }
      },
      "github": {
        "registration": {
          "clientIdSettingName": "GITHUB_CLIENT_ID",
          "clientSecretSettingName": "GITHUB_CLIENT_SECRET"
        }
      }
    }
  },
  "responseOverrides": {
    "401": {
      "redirect": "/ai-360/login.html",
      "statusCode": 302
    },
    "404": {
      "rewrite": "/ai-360/index.html",
      "statusCode": 200
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "Content-Security-Policy": "default-src 'self' https://fonts.googleapis.com https://fonts.gstatic.com https://www.clarity.ms https://scripts.clarity.ms; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'unsafe-inline' https://www.clarity.ms https://scripts.clarity.ms; img-src 'self' data: https:; connect-src 'self' https://www.clarity.ms https://c.clarity.ms",
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
  },
  "mimeTypes": {
    ".json": "text/json",
    ".html": "text/html",
    ".css": "text/css",
    ".js": "application/javascript"
  }
}
